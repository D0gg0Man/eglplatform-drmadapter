+// Import an android_wlegl (hybris client EGL) buffer as a GL_TEXTURE_EXTERNAL_OES
+// texture. The buffer carries a full ANativeWindowBuffer (imported gralloc
+// handle), which the Android EGL imports directly via EGL_NATIVE_BUFFER_ANDROID
+// -- the same path the drmadapter scanout blitter uses. This lets the plain
+// gles2 renderer composite hybris clients on the DRM backend, without the full
+// android renderer (whose per-output EGLSurface model doesn't fit DRM/GBM).
+static struct wlr_texture *android_wlegl_texture_create(
+		struct wlr_gles2_renderer *renderer, struct wlr_android_wlegl_buffer *buffer) {
+	if (!renderer->procs.glEGLImageTargetTexture2DOES ||
+			!renderer->egl->procs.eglCreateImageKHR) {
+		return NULL;
+	}
+	if (buffer->inner.native_buffer == NULL) {
+		return NULL;
+	}
+
+	struct wlr_gles2_texture *texture =
+		gles2_texture_create(renderer, buffer->base.width, buffer->base.height);
+	if (texture == NULL) {
+		return NULL;
+	}
+	texture->drm_format = DRM_FORMAT_INVALID; // sampled only
+	texture->has_alpha = true;
+	texture->target = GL_TEXTURE_EXTERNAL_OES;
+
+	struct wlr_egl_context prev_ctx;
+	wlr_egl_save_context(&prev_ctx);
+	wlr_egl_make_current(renderer->egl);
+
+	struct ANativeWindowBuffer *anwb = &buffer->inner.native_buffer->base;
+	texture->image = renderer->egl->procs.eglCreateImageKHR(renderer->egl->display,
+		EGL_NO_CONTEXT, EGL_NATIVE_BUFFER_ANDROID, (EGLClientBuffer)anwb, NULL);
+	if (texture->image == EGL_NO_IMAGE_KHR) {
+		wlr_log(WLR_ERROR, "Failed to create EGL image from android_wlegl buffer");
+		wlr_egl_restore_context(&prev_ctx);
+		wl_list_remove(&texture->link);
+		free(texture);
+		return NULL;
+	}
+
+	push_gles2_debug(renderer);
+	glGenTextures(1, &texture->tex);
+	glBindTexture(GL_TEXTURE_EXTERNAL_OES, texture->tex);
+	glTexParameteri(GL_TEXTURE_EXTERNAL_OES, GL_TEXTURE_WRAP_S, GL_CLAMP_TO_EDGE);
+	glTexParameteri(GL_TEXTURE_EXTERNAL_OES, GL_TEXTURE_WRAP_T, GL_CLAMP_TO_EDGE);
+	renderer->procs.glEGLImageTargetTexture2DOES(GL_TEXTURE_EXTERNAL_OES, texture->image);
+	glBindTexture(GL_TEXTURE_EXTERNAL_OES, 0);
+	pop_gles2_debug(renderer);
+
+	wlr_egl_restore_context(&prev_ctx);
+	return &texture->wlr_texture;
+}
+
+static struct wlr_texture *gles2_texture_from_android_wlegl(
+		struct wlr_renderer *wlr_renderer, struct wlr_buffer *wlr_buffer) {
+	struct wlr_gles2_renderer *renderer = gles2_get_renderer(wlr_renderer);
+	struct wlr_android_wlegl_buffer *buffer =
+		(struct wlr_android_wlegl_buffer *)wlr_buffer;
+
+	// Like the dmabuf path: cache the texture on the buffer and hold a lock on
+	// it, so wlroots won't send wl_buffer.release (letting the client re-render
+	// into it) while our EXTERNAL_OES texture still samples that gralloc memory.
+	// Without this the client reuses the buffer mid-composite -> flicker.
+	struct wlr_addon *addon =
+		wlr_addon_find(&wlr_buffer->addons, renderer, &texture_addon_impl);
+	if (addon != NULL) {
+		struct wlr_gles2_texture *texture =
+			wl_container_of(addon, texture, buffer_addon);
+		// Re-target the EGL image so we sample the client's current content, not
+		// the stale frame this cached texture last held (see gles2_texture_invalidate).
+		if (!gles2_texture_invalidate(texture)) {
+			return NULL;
+		}
+		wlr_buffer_lock(texture->buffer);
+		return &texture->wlr_texture;
+	}
+
+	struct wlr_texture *wlr_texture = android_wlegl_texture_create(renderer, buffer);
+	if (wlr_texture == NULL) {
+		return NULL;
+	}
+
+	struct wlr_gles2_texture *texture = gles2_get_texture(wlr_texture);
+	texture->buffer = wlr_buffer_lock(wlr_buffer);
+	wlr_addon_init(&texture->buffer_addon, &wlr_buffer->addons,
+		renderer, &texture_addon_impl);
+
+	return &texture->wlr_texture;
+}
+
 struct wlr_texture *gles2_texture_from_buffer(struct wlr_renderer *wlr_renderer,
 		struct wlr_buffer *buffer) {
 	struct wlr_gles2_renderer *renderer = gles2_get_renderer(wlr_renderer);
 
+	if (wlr_android_wlegl_buffer_is_instance(buffer)) {
+		return gles2_texture_from_android_wlegl(wlr_renderer, buffer);
+	}
+
 	void *data;
 	uint32_t format;
 	size_t stride;
