+   * freezes visually (input keeps working) until a restart. A flip normally
+   * completes in <10ms, so frame_pending being set across two 300ms samples
+   * means the completion was lost: force the frame event to restart the loop. */
+  if (dlsym (RTLD_DEFAULT, "drm_shim_panel_is_on")) {
+    self->frame_stuck_count = 0;
