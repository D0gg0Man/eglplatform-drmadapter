 void
 phoc_output_handle_output_power_manager_set_mode (struct wl_listener *listener, void *data)
 {
@@ -1767,6 +1908,43 @@ phoc_output_handle_output_power_manager_set_mode (struct wl_listener *listener,
     return;
   }
 
+  /* On the faked-KMS/hybris (drmadapter) backend, disabling the wlr_output
+   * tears down the mode; the modeset on re-enable then wedges wlroots' frame
+   * scheduling and the screen freezes (and the lockscreen never shows). If the
+   * drmadapter shim is loaded, keep the output enabled and just toggle HWC2
+   * panel power (real backlight off/on) -- no modeset, no freeze. */
+  {
+    static void (*panel_power) (int) = NULL;
+    static gboolean resolved = FALSE;
+    if (!resolved) {
+      panel_power = dlsym (RTLD_DEFAULT, "drm_shim_panel_power");
+      resolved = TRUE;
+    }
+    if (panel_power) {
+      /* On the faked-KMS/hybris (drmadapter) path EVERY compositor-side blank
+       * wedges wlroots' frame loop: disabling the wlr_output tears down the mode
+       * (modeset-on-reenable freeze); even keeping it enabled and only toggling
+       * HWC2 power stalls the synthetic-flip/frame-callback loop so the shell
+       * freezes and never resumes. So the compositor does NOT participate in DPMS
+       * at all -- it stays rendering. phosh's own brightness manager still dims
+       * the backlight on idle (that path works and doesn't freeze), which is the
+       * effective "blank"; any touch/key then wakes because the compositor never
+       * stopped. We DO still confirm the requested mode so phosh's output-power
+       * state stays consistent, but change nothing on the output. */
+      g_message ("phoc: output-power %s (drmadapter path)", enable ? "ON" : "OFF");
+      /* Drive the shim's panel power. Whether that actually toggles HWC2 power
+       * (real DPMS) or is a no-op is decided in drmadapter by DRMADAPTER_HWC2_DPMS
+       * -- with the eventfd flip-wake in place the HWC2 power cycle no longer
+       * wedges the frame clock, so real DPMS can be re-tested. The output stays
+       * enabled either way (no modeset). */
+      panel_power (enable);
+      phoc_output_send_power_mode (self, enable);
+      phoc_output_damage_whole (self);
+      wlr_output_schedule_frame (self->wlr_output);
+      return;
+    }
+  }
+
   current = self->wlr_output->enabled;
   if (enable == current)
     return;
