+/* Tell output-power-management clients (phosh) the real panel power state. We
+ * drive DPMS by toggling HWC2 panel power while keeping the wlr output enabled
+ * (no modeset -> no freeze on the faked-KMS DRM backend), so wlroots' own
+ * commit-based mode events never fire -- send them by hand or phosh desyncs
+ * (stops rendering on blank, never resumes -> lockscreen never shows). */
+static void
+phoc_output_send_power_mode (PhocOutput *output, gboolean on)
+{
+  PhocDesktop *desktop = phoc_server_get_desktop (phoc_server_get_default ());
+  struct wlr_output_power_manager_v1 *mgr = desktop->output_power_manager_v1;
+  struct wlr_output_power_v1 *power;
+
+  if (!mgr)
+    return;
+  wl_list_for_each (power, &mgr->output_powers, link) {
+    if (power->output == output->wlr_output)
+      zwlr_output_power_v1_send_mode (power->resource,
+                                      on ? ZWLR_OUTPUT_POWER_V1_MODE_ON
+                                         : ZWLR_OUTPUT_POWER_V1_MODE_OFF);
+  }
+}
+
+
+/* Force the panel back on (drmadapter/hybris faked-KMS) on input activity and
+ * repaint, so any tap/key wakes the screen even when phosh's lockscreen does
+ * not request the wake; also resync phosh's output-power state. Called from
+ * phoc_desktop_notify_activity(). */
+void
+phoc_output_wake_panel (PhocOutput *output)
+{
+  static int  (*panel_is_on) (void) = NULL;
+  static void (*panel_power) (int)  = NULL;
+  static gboolean resolved = FALSE;
+
+  if (output == NULL)
+    return;
+  if (!resolved) {
+    panel_is_on = dlsym (RTLD_DEFAULT, "drm_shim_panel_is_on");
+    panel_power = dlsym (RTLD_DEFAULT, "drm_shim_panel_power");
+    resolved = TRUE;
+  }
+  if (panel_is_on == NULL || panel_power == NULL || panel_is_on ())
+    return;
+
+  g_message ("phoc: waking panel on input activity");
+  panel_power (1);
+  phoc_output_send_power_mode (output, TRUE);
+  phoc_output_damage_whole (output);
+  /* The synthetic flip clock idles while blanked; damage alone may not restart
+   * wlroots' frame scheduler on the faked-KMS path, so kick it explicitly so a
+   * frame actually gets presented (which is what lights the HWC2 panel). */
+  wlr_output_schedule_frame (output->wlr_output);
+
+  /* Clear phosh's blank: phosh drops PHOSH_STATE_BLANKED (and re-renders the
+   * lockscreen) only when the org.gnome.Mutter.DisplayConfig PowerSaveMode goes
+   * to 0. On this stack input activity never propagates to gnome-session's idle
+   * monitor, so gsd never resets it and phosh stays blanked (black) forever after
+   * a blank. Reset it here on the first input after a blank; the damage_whole
+   * above then bootstraps phosh's redraw via a frame callback. */
+  g_spawn_command_line_async ("gdbus call --session "
+                              "--dest org.gnome.Mutter.DisplayConfig "
+                              "--object-path /org/gnome/Mutter/DisplayConfig "
+                              "--method org.freedesktop.DBus.Properties.Set "
+                              "org.gnome.Mutter.DisplayConfig PowerSaveMode \"<int32 0>\"",
+                              NULL);
+}
+
