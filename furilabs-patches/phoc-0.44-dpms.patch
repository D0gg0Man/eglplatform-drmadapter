+/* See the registration site in phoc_output_initable_init () for why. */
+static gboolean
+phoc_output_frame_watchdog_cb (gpointer data)
+{
+  PhocOutput *self = PHOC_OUTPUT (data);
+
+  if (self->wlr_output == NULL)
+    return G_SOURCE_CONTINUE;
+
+  /* Stuck means: a commit is awaiting its flip completion AND no new commits
+   * are landing. During healthy continuous rendering frame_pending is true a
+   * lot of the time but commit_seq advances every frame -- don't fire then
+   * (a spurious frame event would double-drive the render loop). */
+  if (self->wlr_output->frame_pending &&
+      self->wlr_output->commit_seq == self->frame_watchdog_seq) {
+    if (++self->frame_stuck_count >= 2) {
+      g_message ("phoc: frame_pending stuck on %s (lost flip completion) — forcing frame event",
+                 self->wlr_output->name);
+      self->frame_stuck_count = 0;
+      wlr_output_send_frame (self->wlr_output);
+    }
+  } else {
+    self->frame_stuck_count = 0;
+  }
+  self->frame_watchdog_seq = self->wlr_output->commit_seq;
+
+  return G_SOURCE_CONTINUE;
+}
